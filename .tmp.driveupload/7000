<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Supervisor - Road To</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: #0f172a;
      color: #f8fafc;
      min-height: 100vh;
    }

    .login-screen {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      padding: 20px;
    }

    .login-box {
      background: rgba(30, 41, 59, 0.8);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 24px;
      padding: 40px;
      width: 100%;
      max-width: 400px;
    }

    .dashboard {
      display: none;
      padding: 20px;
    }

    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 30px;
      padding-bottom: 20px;
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px;
      margin-bottom: 30px;
    }

    .stat-card {
      background: rgba(30, 41, 59, 0.6);
      border-radius: 16px;
      padding: 20px;
      border: 1px solid rgba(255,255,255,0.08);
    }

    .stat-value {
      font-size: 32px;
      font-weight: 800;
      color: #3b82f6;
    }

    .drivers-list {
      background: rgba(30, 41, 59, 0.6);
      border-radius: 16px;
      padding: 20px;
      border: 1px solid rgba(255,255,255,0.08);
    }

    .driver-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 15px;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      cursor: pointer;
      transition: all 0.3s;
    }

    .driver-item:hover {
      background: rgba(255,255,255,0.05);
      border-radius: 12px;
    }

    .status-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      display: inline-block;
      margin-right: 10px;
    }

    .status-online { background: #22c55e; box-shadow: 0 0 10px #22c55e; }
    .status-offline { background: #ef4444; }
    .status-paused { background: #f59e0b; }

    #map {
      height: 400px;
      border-radius: 16px;
      margin-top: 20px;
      border: 1px solid rgba(255,255,255,0.1);
    }

    .compliance-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
    }

    .compliant {
      background: rgba(34, 197, 94, 0.15);
      color: #4ade80;
      border: 1px solid rgba(34, 197, 94, 0.3);
    }

    .non-compliant {
      background: rgba(239, 68, 68, 0.15);
      color: #f87171;
      border: 1px solid rgba(239, 68, 68, 0.3);
    }

    input, button {
      width: 100%;
      padding: 14px;
      margin: 10px 0;
      border-radius: 12px;
      border: 1px solid rgba(255,255,255,0.1);
      background: rgba(15, 23, 42, 0.6);
      color: white;
      font-size: 16px;
    }

    button {
      background: linear-gradient(135deg, #3b82f6, #2563eb);
      border: none;
      font-weight: 600;
      cursor: pointer;
    }

    .route-history {
      margin-top: 20px;
      max-height: 300px;
      overflow-y: auto;
    }

    .route-point {
      display: flex;
      align-items: center;
      gap: 15px;
      padding: 10px;
      border-left: 2px solid #3b82f6;
      margin-left: 10px;
    }

    .route-time {
      font-size: 12px;
      color: #64748b;
      min-width: 60px;
    }
  </style>
</head>
<body>

  <!-- Login -->
  <div class="login-screen" id="loginScreen">
    <div class="login-box">
      <h2 style="text-align: center; margin-bottom: 10px;">Panel de Supervisor</h2>
      <p style="text-align: center; color: #64748b; margin-bottom: 30px;">Road To - Monitoreo de Flota</p>
      <input type="email" id="email" placeholder="Correo electrónico" value="">
      <input type="password" id="password" placeholder="Contraseña">
      <button onclick="login()">Ingresar</button>
      <div id="loginError" style="color: #ef4444; text-align: center; margin-top: 10px; display: none;"></div>
    </div>
  </div>

  <!-- Dashboard -->
  <div class="dashboard" id="dashboard">
    <div class="header">
      <div>
        <h2>Panel de Control</h2>
        <p style="color: #64748b; font-size: 14px;">Monitoreo en tiempo real</p>
      </div>
      <button onclick="logout()" style="width: auto; padding: 10px 20px;">Cerrar Sesión</button>
    </div>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-value" id="activeDrivers">0</div>
        <div style="color: #64748b; font-size: 14px;">Conductores Activos</div>
      </div>
      <div class="stat-card">
        <div class="stat-value" id="totalRoutes">0</div>
        <div style="color: #64748b; font-size: 14px;">Rutas Hoy</div>
      </div>
      <div class="stat-card">
        <div class="stat-value" id="complianceRate">0%</div>
        <div style="color: #64748b; font-size: 14px;">Cumplimiento Normas</div>
      </div>
      <div class="stat-card">
        <div class="stat-value" id="alertsToday">0</div>
        <div style="color: #64748b; font-size: 14px;">Alertas Hoy</div>
      </div>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 20px;">
      <div class="drivers-list">
        <h3 style="margin-bottom: 15px;">Conductores</h3>
        <div id="driversList"></div>
      </div>
      
      <div>
        <div style="background: rgba(30, 41, 59, 0.6); border-radius: 16px; padding: 20px; border: 1px solid rgba(255,255,255,0.08);">
          <h3 style="margin-bottom: 15px;">Mapa de Ubicaciones</h3>
          <div id="map"></div>
          
          <div id="driverDetails" style="margin-top: 20px; display: none;">
            <h4 style="margin-bottom: 10px;">Detalles del Conductor</h4>
            <div id="detailsContent"></div>
            
            <h4 style="margin: 20px 0 10px;">Historial de Ruta</h4>
            <div class="route-history" id="routeHistory"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    const SUPABASE_URL = "https://ugchmuhjzzyofoogprlr.supabase.co";
    const SUPABASE_ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...";

    const supabase = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
    let map, markers = {};
    let selectedDriver = null;

    async function login() {
      const email = document.getElementById('email').value;
      const password = document.getElementById('password').value;
      
      const { data, error } = await supabase.auth.signInWithPassword({ email, password });
      
      if (error) {
        document.getElementById('loginError').textContent = error.message;
        document.getElementById('loginError').style.display = 'block';
        return;
      }

      // Verificar si es admin
      const { data: adminData } = await supabase
        .from('admins')
        .select('*')
        .eq('auth_user_id', data.user.id)
        .single();

      if (!adminData) {
        document.getElementById('loginError').textContent = 'Acceso solo para supervisores';
        document.getElementById('loginError').style.display = 'block';
        await supabase.auth.signOut();
        return;
      }

      showDashboard();
    }

    function showDashboard() {
      document.getElementById('loginScreen').style.display = 'none';
      document.getElementById('dashboard').style.display = 'block';
      
      initMap();
      loadDrivers();
      subscribeToLocations();
    }

    function initMap() {
      map = L.map('map').setView([-0.1807, -78.4678], 12);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap'
      }).addTo(map);
    }

    async function loadDrivers() {
      const { data: drivers } = await supabase
        .from('conductores')
        .select('*')
        .order('nombres');

      const list = document.getElementById('driversList');
      list.innerHTML = '';

      drivers.forEach(driver => {
        const item = document.createElement('div');
        item.className = 'driver-item';
        item.onclick = () => selectDriver(driver);
        
        const statusClass = driver.estado === 'activo' ? 'status-online' : 
                           driver.estado === 'pendiente' ? 'status-paused' : 'status-offline';
        
        item.innerHTML = `
          <div>
            <span class="status-dot ${statusClass}"></span>
            <strong>${driver.nombres} ${driver.apellidos}</strong>
            <div style="font-size: 12px; color: #64748b; margin-left: 20px;">${driver.placa}</div>
          </div>
          <span class="compliance-badge ${driver.tiene_aviso_operaciones ? 'compliant' : 'non-compliant'}">
            ${driver.tiene_aviso_operaciones ? '✓ Cumple' : '✗ Pendiente'}
          </span>
        `;
        
        list.appendChild(item);
      });

      updateStats(drivers);
    }

    function updateStats(drivers) {
      const active = drivers.filter(d => d.estado === 'activo').length;
      const compliant = drivers.filter(d => d.tiene_aviso_operaciones).length;
      
      document.getElementById('activeDrivers').textContent = active;
      document.getElementById('complianceRate').textContent = 
        Math.round((compliant / drivers.length) * 100) + '%';
    }

    async function selectDriver(driver) {
      selectedDriver = driver;
      document.getElementById('driverDetails').style.display = 'block';
      
      // Cargar últimas ubicaciones
      const { data: locations } = await supabase
        .from('driver_locations')
        .select('*')
        .eq('driver_id', driver.id)
        .order('timestamp', { ascending: false })
        .limit(50);

      // Mostrar en mapa
      if (locations && locations.length > 0) {
        const lastLoc = locations[0];
        map.setView([lastLoc.latitude, lastLoc.longitude], 15);
        
        // Limpiar marcadores anteriores
        Object.values(markers).forEach(m => map.removeLayer(m));
        
        // Agregar marcador
        const marker = L.marker([lastLoc.latitude, lastLoc.longitude])
          .addTo(map)
          .bindPopup(`${driver.nombres} ${driver.apellidos}<br>${lastLoc.speed ? (lastLoc.speed * 3.6).toFixed(0) + ' km/h' : 'Sin movimiento'}`);
        
        markers[driver.id] = marker;
        
        // Dibujar ruta
        const latlngs = locations.map(l => [l.latitude, l.longitude]).reverse();
        L.polyline(latlngs, { color: '#3b82f6', weight: 3, opacity: 0.7 }).addTo(map);
        
        // Mostrar historial
        const history = document.getElementById('routeHistory');
        history.innerHTML = locations.slice(0, 10).map(loc => `
          <div class="route-point">
            <div class="route-time">${new Date(loc.timestamp).toLocaleTimeString()}</div>
            <div>
              <div>Velocidad: ${loc.speed ? (loc.speed * 3.6).toFixed(0) : 0} km/h</div>
              <div style="font-size: 12px; color: #64748b;">
                Precisión: ${loc.accuracy?.toFixed(0) || 'N/A'} m
              </div>
            </div>
          </div>
        `).join('');
      }

      // Mostrar detalles
      document.getElementById('detailsContent').innerHTML = `
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
          <div><strong>Vehículo:</strong> ${driver.marca} ${driver.modelo}</div>
          <div><strong>Placa:</strong> ${driver.placa}</div>
          <div><strong>Licencia:</strong> ${driver.licencia}</div>
          <div><strong>Teléfono:</strong> ${driver.celular}</div>
          <div><strong>Aviso Operaciones:</strong> 
            <span class="compliance-badge ${driver.tiene_aviso_operaciones ? 'compliant' : 'non-compliant'}">
              ${driver.tiene_aviso_operaciones ? '✓ Registrado' : '✗ Pendiente'}
            </span>
          </div>
          <div><strong>Propietario:</strong> ${driver.es_propietario ? 'Sí' : 'No (tercero)'}</div>
        </div>
      `;
    }

    function subscribeToLocations() {
      supabase
        .channel('driver_locations')
        .on('postgres_changes', 
          { event: 'INSERT', schema: 'public', table: 'driver_locations' },
          (payload) => {
            // Actualizar marcador en tiempo real
            const loc = payload.new;
            if (markers[loc.driver_id]) {
              markers[loc.driver_id].setLatLng([loc.latitude, loc.longitude]);
            }
          }
        )
        .subscribe();
    }

    async function logout() {
      await supabase.auth.signOut();
      location.reload();
    }
  </script>

</body>
</html>